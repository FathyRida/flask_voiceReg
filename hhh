#!/bin/bash

################################################################################
# hvault.sh - Fetch credentials from Vault using instance.conf
# 
# NOW WITH MOUNT SUPPORT!
#
# Usage:
#   ./hvault.sh -b oracle/qua -m cloud -c instance.conf
#
# In your code:
#   eval "$(./hvault.sh -b oracle/qua -m cloud -c instance.conf)"
#   echo $oracle_OWN_AP11436
#
################################################################################

set -euo pipefail

VAULT_ADDR="${VAULT_ADDR:-}"
VAULT_TOKEN="${VAULT_TOKEN:-}"
VAULT_NAMESPACE="${VAULT_NAMESPACE:-}"
VAULT_SKIP_VERIFY="${VAULT_SKIP_VERIFY:-false}"

BASE_PATH="oracle/qua"
MOUNT="cloud"  # ← The mount point! Change to your mount if different
CONF_FILE=""
OUTPUT_FORMAT="export"

# ============================================================================
# FUNCTIONS
# ============================================================================

error() {
    echo "[ERROR] $*" >&2
    exit 1
}

vault_api() {
    local method=$1
    local path=$2
    local skip_verify=""
    
    [ "$VAULT_SKIP_VERIFY" = true ] && skip_verify="-k"
    
    local headers=(-H "X-Vault-Token: $VAULT_TOKEN")
    [ -n "$VAULT_NAMESPACE" ] && headers+=(-H "X-Vault-Namespace: $VAULT_NAMESPACE")
    
    # Build the correct API path with namespace and mount
    local api_url="$VAULT_ADDR/v1"
    [ -n "$VAULT_NAMESPACE" ] && api_url="$api_url/$VAULT_NAMESPACE"
    api_url="$api_url/$MOUNT/$path"
    
    curl -s $skip_verify -X "$method" "${headers[@]}" \
        -H "Content-Type: application/json" \
        "$api_url"
}

vault_get_secret() {
    local secret_path=$1
    local response=$(vault_api GET "data/$secret_path")
    
    if echo "$response" | jq -e '.data.data' &>/dev/null; then
        echo "$response" | jq '.data.data'
        return 0
    fi
    return 1
}

# ============================================================================
# MAIN
# ============================================================================

usage() {
    cat <<'EOF'
Fetch credentials from Vault using instance.conf

Usage: ./hvault.sh -b BASE_PATH -m MOUNT -c CONF_FILE

OPTIONS:
  -b BASE_PATH        Base path in Vault (default: oracle/qua)
                      Examples:
                        oracle/qua   (QA environment)
                        oracle/prod  (Production)
                        oracle/dev   (Development)
  
  -m MOUNT            Vault mount point (default: cloud)
                      Examples:
                        cloud       (KV v2 mount at "cloud")
                        secret      (KV v2 mount at "secret")
                        kv          (KV v2 mount at "kv")
  
  -c CONF_FILE        Config file with instance list - REQUIRED
  -f FORMAT           Output format: export, prm, json (default: export)
  -h, --help          Show help

CONF FILE FORMAT:
  # Format: ENVIRONMENT/INSTANCE (e.g., Q0015185/DYNATRACE)
  # One per line
  
  Example instance.conf:
    Q0015185/DYNATRACE
    Q0015185/OWN_AP11436
    Q0015185/ICUWSV
    Q001518C/DYNATRACE

USAGE IN YOUR CODE:

  # QA environment with cloud mount
  eval "$(./hvault.sh -b oracle/qua -m cloud -c instance.conf)"
  echo $oracle_DYNATRACE

  # Production
  eval "$(./hvault.sh -b oracle/prod -m cloud -c instance.conf)"
  
  # Development
  eval "$(./hvault.sh -b oracle/dev -m cloud -c instance.conf)"

VAULT API STRUCTURE:
  
  Your Vault: /v1/{NAMESPACE}/{MOUNT}/data/{BASE_PATH}/{ENV}/{INSTANCE}
  
  Example:
    Namespace: AP11436
    Mount: cloud
    Base Path: oracle/qua
    Env: Q0015185
    Instance: OWN_AP11436
    
  Full API: /v1/AP11436/cloud/data/oracle/qua/Q0015185/OWN_AP11436

EOF
    exit 1
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -b|--base-path)
            shift
            BASE_PATH="$1"
            ;;
        -m|--mount)
            shift
            MOUNT="$1"
            ;;
        -c|--config)
            shift
            CONF_FILE="$1"
            ;;
        -f|--format)
            shift
            OUTPUT_FORMAT="$1"
            ;;
        -h|--help)
            usage
            ;;
        *)
            error "Unknown option: $1"
            ;;
    esac
    shift
done

# Validate
[ -z "$VAULT_ADDR" ] && error "VAULT_ADDR not set"
[ -z "$VAULT_TOKEN" ] && error "VAULT_TOKEN not set"
[ -z "$CONF_FILE" ] && error "Config file (-c) required"
[ ! -f "$CONF_FILE" ] && error "Config file not found: $CONF_FILE"

# Process each instance from config file
while IFS= read -r line; do
    # Skip empty lines and comments
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^# ]] && continue
    
    # Trim whitespace
    line=$(echo "$line" | xargs)
    
    # Parse format: ENVIRONMENT/INSTANCE
    IFS='/' read -r env instance <<< "$line"
    
    if [[ -z "$instance" ]]; then
        error "Invalid format in $CONF_FILE: $line (expected ENV/INSTANCE)"
    fi
    
    # Fetch from Vault (with correct mount path)
    secret_path="$BASE_PATH/$env/$instance"
    
    if secret_data=$(vault_get_secret "$secret_path" 2>/dev/null); then
        username=$(echo "$secret_data" | jq -r '.username // "UNKNOWN"')
        password=$(echo "$secret_data" | jq -r '.password // "UNKNOWN"')
        pdb=$(echo "$secret_data" | jq -r '.pdb // "UNKNOWN"')
        service=$(echo "$secret_data" | jq -r '.service // "UNKNOWN"')
        dns=$(echo "$secret_data" | jq -r '.dns_aliases[0] // "UNKNOWN"')
        port=$(echo "$secret_data" | jq -r '.port_tcp // 1521')
        
        var_name="${instance}"
        
        # Output in selected format
        case "$OUTPUT_FORMAT" in
            export)
                echo "export oracle_${var_name}=\"${pdb}/${username}@${service}\""
                echo "export instance_${var_name}=\"${pdb}P10\""
                echo "export dns_${var_name}=\"${dns}:${port}\""
                ;;
            prm)
                echo "#connection $var_name"
                echo "oracle_${var_name}=${pdb}/${username}@***"
                echo "instance_${var_name}:${pdb}P10"
                echo ""
                ;;
            json)
                echo "{\"instance\": \"$var_name\", \"env\": \"$env\", \"pdb\": \"$pdb\", \"username\": \"$username\", \"service\": \"$service\", \"dns\": \"$dns\", \"port\": $port}"
                ;;
        esac
    else
        echo "[ERROR] Failed to fetch $instance from $BASE_PATH/$env in Vault (mount: $MOUNT)" >&2
    fi
    
done < "$CONF_FILE"
