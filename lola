#!/bin/bash

################################################################################
# hvault.sh - Fetch credentials from Vault using instance.conf
# 
# EXACTLY LIKE lisa.sh - PROVEN TO WORK!
#
# Usage:
#   ./hvault.sh -c instance.conf
#
# Config file format:
#   cloud/oracle/qua/Q0015185/DYNATRACE
#   cloud/oracle/qua/Q0015185/OWN_AP11436
#
# In your code:
#   eval "$(./hvault.sh -c instance.conf)"
#   echo $oracle_DYNATRACE
#
################################################################################

set -euo pipefail

VAULT_ADDR="${VAULT_ADDR:-}"
VAULT_TOKEN="${VAULT_TOKEN:-}"
VAULT_NAMESPACE="${VAULT_NAMESPACE:-}"

CONF_FILE=""
OUTPUT_FORMAT="export"

# ============================================================================
# FUNCTIONS
# ============================================================================

error() {
    echo "[ERROR] $*" >&2
    exit 1
}

# ============================================================================
# MAIN
# ============================================================================

usage() {
    cat <<'EOF'
Fetch credentials from Vault using instance.conf

Usage: ./hvault.sh -c CONF_FILE

OPTIONS:
  -c CONF_FILE        Config file with Vault paths - REQUIRED
  -f FORMAT           Output format: export, prm, json (default: export)
  -h, --help          Show help

CONF FILE FORMAT:
  # Format: <mount>/<key/path>
  # One per line
  
  Example instance.conf:
    cloud/oracle/qua/Q0015185/DYNATRACE
    cloud/oracle/qua/Q0015185/OWN_AP11436
    cloud/oracle/qua/Q0015185/ICUWSV
    cloud/oracle/qua/Q001518C/DYNATRACE

USAGE:

  eval "$(./hvault.sh -c instance.conf)"
  echo $oracle_DYNATRACE

VAULT API STRUCTURE:

  Format: /v1/{NAMESPACE}/{MOUNT}/data/{KEY_PATH}
  
  Example:
    Namespace: AP11436
    Mount: cloud
    Key Path: oracle/qua/Q0015185/OWN_AP11436
    
  Full API: /v1/AP11436/cloud/data/oracle/qua/Q0015185/OWN_AP11436

EOF
    exit 1
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -c|--config)
            shift
            CONF_FILE="$1"
            ;;
        -f|--format)
            shift
            OUTPUT_FORMAT="$1"
            ;;
        -h|--help)
            usage
            ;;
        *)
            error "Unknown option: $1"
            ;;
    esac
    shift
done

# Validate
[ -z "$VAULT_ADDR" ] && error "VAULT_ADDR not set"
[ -z "$VAULT_TOKEN" ] && error "VAULT_TOKEN not set"
[ -z "$CONF_FILE" ] && error "Config file (-c) required"
[ ! -f "$CONF_FILE" ] && error "Config file not found: $CONF_FILE"

# Process each path from config file
while IFS= read -r line; do
    # Skip empty lines and comments
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^# ]] && continue
    
    # Trim whitespace
    line=$(echo "$line" | xargs)
    
    # Parse using SAME method as lisa.sh
    # Format: <mount>/<key_path>
    # Example: cloud/oracle/qua/Q0015185/OWN_AP11436
    
    mount="${line%%/*}"        # Get mount (first part before /)
    key="${line#*/}"           # Get rest (everything after first /)
    
    if [[ -z "$mount" ]] || [[ -z "$key" ]]; then
        error "Invalid format in $CONF_FILE: $line (expected mount/path)"
    fi
    
    # Build Vault API URL EXACTLY like lisa.sh
    data_url="${VAULT_ADDR}/v1/${VAULT_NAMESPACE}/${mount}/data/${key}"
    
    # Fetch from Vault using curl EXACTLY like lisa.sh
    if resp=$(curl -sS --fail \
        -H "X-Vault-Token: ${VAULT_TOKEN}" \
        "$data_url" 2>/dev/null); then
        
        # Extract secret data
        secret_data=$(echo "$resp" | jq '.data.data' 2>/dev/null)
        
        if [ -z "$secret_data" ] || [ "$secret_data" = "null" ]; then
            echo "[ERROR] No data in response for $key" >&2
            continue
        fi
        
        # Parse fields
        username=$(echo "$secret_data" | jq -r '.username // "UNKNOWN"')
        pdb=$(echo "$secret_data" | jq -r '.pdb // "UNKNOWN"')
        service=$(echo "$secret_data" | jq -r '.service // "UNKNOWN"')
        dns=$(echo "$secret_data" | jq -r '.dns_aliases[0] // "UNKNOWN"')
        port=$(echo "$secret_data" | jq -r '.port_tcp // 1521')
        
        # Use last path component as variable name
        var_name="${key##*/}"
        
        # Output in selected format
        case "$OUTPUT_FORMAT" in
            export)
                echo "export oracle_${var_name}=\"${pdb}/${username}@${service}\""
                echo "export instance_${var_name}=\"${pdb}P10\""
                echo "export dns_${var_name}=\"${dns}:${port}\""
                ;;
            prm)
                echo "#connection $var_name"
                echo "oracle_${var_name}=${pdb}/${username}@***"
                echo "instance_${var_name}:${pdb}P10"
                echo ""
                ;;
            json)
                echo "{\"instance\": \"$var_name\", \"path\": \"$key\", \"pdb\": \"$pdb\", \"username\": \"$username\", \"service\": \"$service\"}"
                ;;
        esac
    else
        echo "[ERROR] Failed to fetch $key from Vault (mount: $mount)" >&2
    fi
    
done < "$CONF_FILE"
