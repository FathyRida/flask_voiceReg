#!/bin/bash

################################################################################
# DEBUG: Test Vault connectivity and permissions
################################################################################

set -euo pipefail

VAULT_ADDR="${VAULT_ADDR:-}"
VAULT_TOKEN="${VAULT_TOKEN:-}"
VAULT_NAMESPACE="${VAULT_NAMESPACE:-}"
VAULT_SKIP_VERIFY="${VAULT_SKIP_VERIFY:-false}"

echo "=========================================="
echo "VAULT DEBUG TESTS"
echo "=========================================="
echo ""

# Test 1: Check variables are set
echo "TEST 1: Environment Variables"
echo "────────────────────────────"
echo "VAULT_ADDR: ${VAULT_ADDR:-NOT SET ❌}"
echo "VAULT_TOKEN: ${VAULT_TOKEN:0:10}... (${#VAULT_TOKEN} chars)"
echo "VAULT_NAMESPACE: ${VAULT_NAMESPACE:-<none>}"
echo ""

if [ -z "$VAULT_ADDR" ] || [ -z "$VAULT_TOKEN" ]; then
    echo "❌ VAULT_ADDR or VAULT_TOKEN not set!"
    echo ""
    echo "Set them:"
    echo "  export VAULT_ADDR=https://vault.example.com"
    echo "  export VAULT_TOKEN=hvs.CAA..."
    exit 1
fi

# Test 2: Can we reach Vault?
echo "TEST 2: Vault Connectivity"
echo "─────────────────────────"

skip_verify=""
[ "$VAULT_SKIP_VERIFY" = true ] && skip_verify="-k"

response=$(curl -s $skip_verify -w "\n%{http_code}" \
    -H "X-Vault-Token: $VAULT_TOKEN" \
    "$VAULT_ADDR/v1/sys/health" 2>&1)

http_code=$(echo "$response" | tail -1)
body=$(echo "$response" | head -n -1)

echo "HTTP Status: $http_code"

if [ "$http_code" = "200" ]; then
    echo "✓ Connected to Vault"
    echo "$body" | jq . 2>/dev/null || echo "$body"
else
    echo "❌ Failed to connect"
    echo "Response: $body"
    exit 1
fi

echo ""

# Test 3: Is token valid?
echo "TEST 3: Token Validity"
echo "────────────────────"

token_response=$(curl -s $skip_verify -w "\n%{http_code}" \
    -H "X-Vault-Token: $VAULT_TOKEN" \
    "$VAULT_ADDR/v1/auth/token/lookup-self" 2>&1)

token_http=$(echo "$token_response" | tail -1)
token_body=$(echo "$token_response" | head -n -1)

if [ "$token_http" = "200" ]; then
    echo "✓ Token is valid"
    echo "$token_body" | jq '.data | {id, policies, ttl}' 2>/dev/null
else
    echo "❌ Token is invalid or expired"
    echo "Status: $token_http"
    exit 1
fi

echo ""

# Test 4: Can we list oracle/qua?
echo "TEST 4: List oracle/qua Path"
echo "────────────────────────────"

list_response=$(curl -s $skip_verify -w "\n%{http_code}" \
    -X LIST \
    -H "X-Vault-Token: $VAULT_TOKEN" \
    -H "X-Vault-Namespace: ${VAULT_NAMESPACE:-}" \
    "$VAULT_ADDR/v1/data/oracle/qua" 2>&1)

list_http=$(echo "$list_response" | tail -1)
list_body=$(echo "$list_response" | head -n -1)

if [ "$list_http" = "200" ]; then
    echo "✓ Can list oracle/qua"
    echo "Environments found:"
    echo "$list_body" | jq -r '.data.keys[]' 2>/dev/null | head -5
else
    echo "❌ Cannot list oracle/qua"
    echo "Status: $list_http"
    echo "Response: $list_body"
fi

echo ""

# Test 5: Can we list Q001518C instances?
echo "TEST 5: List Q001518C Instances"
echo "──────────────────────────────"

q_response=$(curl -s $skip_verify -w "\n%{http_code}" \
    -X LIST \
    -H "X-Vault-Token: $VAULT_TOKEN" \
    -H "X-Vault-Namespace: ${VAULT_NAMESPACE:-}" \
    "$VAULT_ADDR/v1/data/oracle/qua/Q001518C" 2>&1)

q_http=$(echo "$q_response" | tail -1)
q_body=$(echo "$q_response" | head -n -1)

if [ "$q_http" = "200" ]; then
    echo "✓ Can list Q001518C instances"
    echo "Instances found:"
    echo "$q_body" | jq -r '.data.keys[]' 2>/dev/null
else
    echo "❌ Cannot list Q001518C"
    echo "Status: $q_http"
    echo "Response: $q_body"
fi

echo ""

# Test 6: Can we fetch OWN_AP11436?
echo "TEST 6: Fetch OWN_AP11436 Secret"
echo "────────────────────────────────"

secret_response=$(curl -s $skip_verify -w "\n%{http_code}" \
    -H "X-Vault-Token: $VAULT_TOKEN" \
    -H "X-Vault-Namespace: ${VAULT_NAMESPACE:-}" \
    "$VAULT_ADDR/v1/data/oracle/qua/Q001518C/OWN_AP11436" 2>&1)

secret_http=$(echo "$secret_response" | tail -1)
secret_body=$(echo "$secret_response" | head -n -1)

if [ "$secret_http" = "200" ]; then
    echo "✓ Can fetch OWN_AP11436"
    echo "Secret data:"
    echo "$secret_body" | jq '.data.data | {username, pdb, service}' 2>/dev/null
else
    echo "❌ Cannot fetch OWN_AP11436"
    echo "Status: $secret_http"
    echo "Response: $secret_body"
fi

echo ""
echo "=========================================="
echo "SUMMARY"
echo "=========================================="

if [ "$secret_http" = "200" ]; then
    echo "✓ Everything works! Run hvault.sh"
else
    echo "❌ Issue found above. Check:"
    echo "  1. VAULT_ADDR is correct URL"
    echo "  2. VAULT_TOKEN is valid and not expired"
    echo "  3. Token has policy for oracle/qua/* paths"
    echo "  4. VAULT_NAMESPACE is correct (if using namespaces)"
fi
