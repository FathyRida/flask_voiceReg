#!/bin/bash

################################################################################
# hvault.sh
# Purpose: Fetch Oracle credentials from HashiCorp Vault and inject into
#          static connection file structure, maintaining all original formatting
# Author: Rida
# Usage: ./hvault.sh -c CONF_FILE -s STATIC_CONN_FILE [-b BASE_PATH]
################################################################################

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default values
VAULT_ADDR="${VAULT_ADDR:-}"
VAULT_TOKEN="${VAULT_TOKEN:-}"
VAULT_NAMESPACE="${VAULT_NAMESPACE:-}"
VAULT_SKIP_VERIFY="${VAULT_SKIP_VERIFY:-false}"
MOUNT="cloud"
BASE_PATH="oracle/qua"
CONF_FILE=""
STATIC_CONN_FILE=""

# Debug mode
DEBUG="${DEBUG:-false}"

################################################################################
# FUNCTIONS
################################################################################

# Print with colors
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1" >&2
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1" >&2
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1" >&2
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

log_debug() {
    if [[ "$DEBUG" == "true" ]]; then
        echo -e "${BLUE}[DEBUG]${NC} $1" >&2
    fi
}

# Print usage
usage() {
    cat <<EOF
Usage: $0 -c CONFIG_FILE -s STATIC_CONN_FILE [OPTIONS]

Required Arguments:
  -c CONF_FILE              Configuration file with instances list
  -s STATIC_CONN_FILE       Static connections file with placeholders

Optional Arguments:
  -b BASE_PATH              Base path in Vault (default: oracle/qua)
  -h, --help                Show this help message

Environment Variables:
  VAULT_ADDR                Vault server address (required)
  VAULT_TOKEN               Vault authentication token (required)
  VAULT_NAMESPACE           Vault namespace (default: AP11436)
  VAULT_SKIP_VERIFY         Skip SSL verification (default: false)
  DEBUG                     Enable debug mode (default: false)

Examples:
  ./hvault.sh -c instances.conf -s static_connections.conf
  
  DEBUG=true ./hvault.sh -c instances.conf -s static_connections.conf -b oracle/prod

EOF
    exit 1
}

# Validate required environment variables
validate_environment() {
    log_debug "Validating environment variables..."
    
    if [[ -z "$VAULT_ADDR" ]]; then
        log_error "VAULT_ADDR environment variable not set"
        exit 1
    fi
    
    if [[ -z "$VAULT_TOKEN" ]]; then
        log_error "VAULT_TOKEN environment variable not set"
        exit 1
    fi
    
    if [[ -z "$VAULT_NAMESPACE" ]]; then
        log_warn "VAULT_NAMESPACE not set, using default: AP11436"
        VAULT_NAMESPACE="AP11436"
    fi
    
    log_debug "VAULT_ADDR: $VAULT_ADDR"
    log_debug "VAULT_NAMESPACE: $VAULT_NAMESPACE"
    log_debug "VAULT_SKIP_VERIFY: $VAULT_SKIP_VERIFY"
}

# Validate required files
validate_files() {
    log_debug "Validating configuration files..."
    
    if [[ -z "$CONF_FILE" ]]; then
        log_error "Configuration file (-c) is required"
        usage
    fi
    
    if [[ -z "$STATIC_CONN_FILE" ]]; then
        log_error "Static connections file (-s) is required"
        usage
    fi
    
    if [[ ! -f "$CONF_FILE" ]]; then
        log_error "Configuration file not found: $CONF_FILE"
        exit 1
    fi
    
    if [[ ! -f "$STATIC_CONN_FILE" ]]; then
        log_error "Static connections file not found: $STATIC_CONN_FILE"
        exit 1
    fi
    
    log_debug "CONF_FILE: $CONF_FILE"
    log_debug "STATIC_CONN_FILE: $STATIC_CONN_FILE"
    log_debug "BASE_PATH: $BASE_PATH"
}

# Fetch password from Vault for a given instance
fetch_password_from_vault() {
    local instance="$1"
    local env="${instance: -2}"  # Extract last 2 characters (QA/PR/PD)
    local key_path="${BASE_PATH}/${env}/${instance}"
    
    log_debug "Fetching password from Vault for instance: $instance"
    log_debug "Vault path: ${VAULT_NAMESPACE}/${MOUNT}/data/${key_path}"
    
    local curl_opts=(-s -S)
    
    # Add SSL skip verification if needed
    if [[ "$VAULT_SKIP_VERIFY" == "true" ]]; then
        curl_opts+=(-k)
    fi
    
    # Make API call to Vault
    local response
    response=$(curl "${curl_opts[@]}" \
        -H "X-Vault-Token: ${VAULT_TOKEN}" \
        -H "X-Vault-Namespace: ${VAULT_NAMESPACE}" \
        "${VAULT_ADDR}/v1/${VAULT_NAMESPACE}/${MOUNT}/data/${key_path}" 2>&1) || {
        log_error "Failed to fetch credentials for $instance from Vault"
        log_debug "Response: $response"
        return 1
    }
    
    log_debug "Vault response received for $instance"
    
    # Parse password from response using jq
    local password
    password=$(echo "$response" | jq -r '.data.data.password // empty' 2>/dev/null) || {
        log_error "Failed to parse Vault response for $instance"
        log_debug "Response: $response"
        return 1
    }
    
    if [[ -z "$password" ]]; then
        log_error "No password found in Vault for instance: $instance"
        return 1
    fi
    
    echo "$password"
    return 0
}

# Extract instance name from a connection line
extract_instance_from_line() {
    local line="$1"
    
    # Match oracle=INSTANCE/... pattern and extract INSTANCE
    # This handles formats like:
    # oracle=Q001518C/placeholder
    # connection:oracle=Q001518C/placeholder
    # oracle=Q001518C/"password"
    
    local instance
    instance=$(echo "$line" | grep -oP 'oracle=\K[^/]+' | head -1)
    
    if [[ -z "$instance" ]]; then
        log_debug "No instance found in line: $line"
        return 1
    fi
    
    echo "$instance"
    return 0
}

# Replace password in a connection line
replace_password_in_line() {
    local line="$1"
    local new_password="$2"
    
    # Escape special characters in password for sed
    local escaped_password
    escaped_password=$(printf '%s\n' "$new_password" | sed -e 's/[\/&]/\\&/g')
    
    # Replace everything after oracle=INSTANCE/ with new password
    # Pattern: oracle=INSTANCE/OLD_PASSWORD -> oracle=INSTANCE/NEW_PASSWORD
    local updated_line
    updated_line=$(echo "$line" | sed "s|\(oracle=[^/]*\)/[^\"[:space:]]*|\1/$escaped_password|")
    
    echo "$updated_line"
}

# Process static connections file and inject passwords from Vault
process_static_connections() {
    local static_file="$1"
    local line_num=0
    local success_count=0
    local error_count=0
    
    log_info "Starting to process static connections file: $static_file"
    
    while IFS= read -r line || [[ -n "$line" ]]; do
        ((line_num++))
        
        # Skip empty lines
        if [[ -z "$line" || "$line" =~ ^[[:space:]]*$ ]]; then
            log_debug "Line $line_num: Empty line, skipping"
            echo "$line"
            continue
        fi
        
        # Skip comment lines
        if [[ "$line" =~ ^[[:space:]]*# ]]; then
            log_debug "Line $line_num: Comment line, keeping as-is"
            echo "$line"
            continue
        fi
        
        log_debug "Processing line $line_num: $line"
        
        # Extract instance name from the line
        local instance
        if ! instance=$(extract_instance_from_line "$line"); then
            log_warn "Line $line_num: No instance found, keeping as-is"
            echo "$line"
            continue
        fi
        
        log_info "Line $line_num: Found instance '$instance'"
        
        # Fetch password from Vault
        local password
        if ! password=$(fetch_password_from_vault "$instance"); then
            log_error "Line $line_num: Failed to fetch password for $instance"
            echo "[ERROR] $line" | sed 's/^/# /'  # Comment out the line as error marker
            ((error_count++))
            continue
        fi
        
        # Replace password in the line
        local updated_line
        updated_line=$(replace_password_in_line "$line" "$password")
        
        log_success "Line $line_num: Password injected for instance '$instance'"
        log_debug "Original: $line"
        log_debug "Updated:  $updated_line"
        
        echo "$updated_line"
        ((success_count++))
        
    done < "$static_file"
    
    # Print summary to stderr
    log_info "Processing complete:"
    log_success "  Successfully processed: $success_count lines"
    if [[ $error_count -gt 0 ]]; then
        log_error "  Failed to process: $error_count lines"
    fi
    
    if [[ $error_count -gt 0 ]]; then
        return 1
    fi
    return 0
}

################################################################################
# MAIN EXECUTION
################################################################################

main() {
    # Parse command-line arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -c)
                CONF_FILE="$2"
                shift 2
                ;;
            -s)
                STATIC_CONN_FILE="$2"
                shift 2
                ;;
            -b)
                BASE_PATH="$2"
                shift 2
                ;;
            -h|--help)
                usage
                ;;
            *)
                log_error "Unknown option: $1"
                usage
                ;;
        esac
    done
    
    # Validate inputs
    validate_environment
    validate_files
    
    log_info "========================================="
    log_info "hvault.sh - Vault Password Injector"
    log_info "========================================="
    
    # Process the static connections file
    if ! process_static_connections "$STATIC_CONN_FILE"; then
        log_error "Failed to process some connections"
        exit 1
    fi
    
    log_success "All operations completed successfully!"
    exit 0
}

# Run main function
main "$@"
