#!/usr/bin/env python3
"""
Liste toutes les versions d'un secret Vault (KV v2) avec leur statut.

Install:
    pip install hvac

Usage:
    export VAULT_ADDR="https://vault.example.com"
    export VAULT_TOKEN="hvs.xxxxx"

    python vault_versions.py secret/ma-cle
"""

import os
import sys
import hvac
from datetime import datetime

client = hvac.Client(
    url=os.environ.get("VAULT_ADDR", "http://127.0.0.1:8200"),
    token=os.environ.get("VAULT_TOKEN"),
)

MOUNT = "secret"  # adapte si ton KV v2 est monté ailleurs


def _key(path):
    return path.split("/", 1)[1]


def version_status(info):
    """Détermine le statut d'une version à partir de ses métadonnées."""
    if info.get("destroyed"):
        return "DESTROYED"
    # deletion_time non vide => soft-deleted
    if info.get("deletion_time"):
        return "DELETED"
    return "ACTIVE"


def list_versions(path):
    meta = client.secrets.kv.v2.read_secret_metadata(
        path=_key(path), mount_point=MOUNT
    )["data"]

    versions = meta.get("versions", {})
    current = meta["current_version"]

    print(f"Path             : {path}")
    print(f"Version actuelle : v{current}")
    print(f"Total versions   : {len(versions)}")
    print("-" * 60)
    print(f"{'VERSION':<10}{'STATUT':<14}{'CRÉÉE LE':<26}")
    print("-" * 60)

    # tri numérique par numéro de version
    for v in sorted(versions, key=lambda x: int(x)):
        info = versions[v]
        status = version_status(info)
        created = info.get("created_time", "")
        marker = "  <- current" if int(v) == current else ""
        print(f"v{v:<9}{status:<14}{created:<26}{marker}")


if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: python vault_versions.py <mount/key>")
        sys.exit(1)
    list_versions(sys.argv[1])
